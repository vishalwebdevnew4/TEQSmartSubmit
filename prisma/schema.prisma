generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Admin {
  id           Int             @id @default(autoincrement())
  username     String          @unique
  passwordHash String
  isActive     Boolean         @default(true)
  createdAt    DateTime        @default(now())
  submissions  SubmissionLog[]
  batchRuns    AutomationBatchRun[]
}

model Domain {
  id                 Int             @id @default(autoincrement())
  url                String          @unique
  category           String?
  customMessage      String?         // Custom message to use for this domain's form submissions
  isActive           Boolean         @default(true)
  contactPageUrl     String?
  contactCheckStatus String? // "pending", "found", "not_found", "error", "no_form"
  contactCheckedAt   DateTime?
  createdAt          DateTime        @default(now())
  templates          Template[]
  submissions        SubmissionLog[]
  contactChecks      ContactCheck[]
  batchItems         AutomationBatchItem[]
  currentBatchRuns   AutomationBatchRun[] @relation("CurrentBatchDomain")
}

model Template {
  id            Int             @id @default(autoincrement())
  name          String          @unique
  description   String?
  fieldMappings Json
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  domainId      Int?
  domain        Domain?         @relation(fields: [domainId], references: [id], onDelete: SetNull)
  submissions   SubmissionLog[]
  batchItems    AutomationBatchItem[]
}

model SubmissionLog {
  id         Int       @id @default(autoincrement())
  url        String
  status     String
  message    String?
  createdAt  DateTime  @default(now())
  finishedAt DateTime?
  domainId   Int?
  templateId Int?
  domain     Domain?   @relation(fields: [domainId], references: [id], onDelete: SetNull)
  template   Template? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  adminId    Int?
  admin      Admin?    @relation(fields: [adminId], references: [id], onDelete: SetNull)
  batchRunId Int?
  batchRun   AutomationBatchRun?  @relation(fields: [batchRunId], references: [id], onDelete: SetNull)
  batchRunItemId Int?
  batchRunItem   AutomationBatchItem? @relation(fields: [batchRunItemId], references: [id], onDelete: SetNull)
}

model AutomationBatchRun {
  id               Int                  @id @default(autoincrement())
  status           String               @default("pending")
  mode             String               @default("bulk")
  source           String?
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  startedAt        DateTime?
  pausedAt         DateTime?
  finishedAt       DateTime?
  cancelledAt      DateTime?
  batchSize        Int                  @default(10)
  delaySeconds     Int                  @default(5)
  retryLimit       Int                  @default(2)
  totalDomains     Int                  @default(0)
  processedDomains Int                  @default(0)
  successCount     Int                  @default(0)
  failureCount     Int                  @default(0)
  skippedCount     Int                  @default(0)
  pendingCount     Int                  @default(0)
  currentDomainId  Int?
  lastError        String?
  notes            String?
  startedByAdminId Int?
  startedByAdmin   Admin?               @relation(fields: [startedByAdminId], references: [id], onDelete: SetNull)
  currentDomain    Domain?              @relation("CurrentBatchDomain", fields: [currentDomainId], references: [id], onDelete: SetNull)
  items            AutomationBatchItem[]
  submissions      SubmissionLog[]

  @@index([status, createdAt])
  @@index([startedByAdminId])
  @@index([currentDomainId])
}

model AutomationBatchItem {
  id                  Int                 @id @default(autoincrement())
  batchRunId          Int
  domainId            Int
  templateId          Int?
  sequence            Int
  status              String              @default("pending")
  attemptCount        Int                 @default(0)
  startedAt           DateTime?
  finishedAt          DateTime?
  skipReason          String?
  lastError           String?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  batchRun            AutomationBatchRun  @relation(fields: [batchRunId], references: [id], onDelete: Cascade)
  domain              Domain              @relation(fields: [domainId], references: [id], onDelete: Cascade)
  template            Template?           @relation(fields: [templateId], references: [id], onDelete: SetNull)
  submissions         SubmissionLog[]

  @@unique([batchRunId, domainId])
  @@index([batchRunId, sequence])
  @@index([status, updatedAt])
  @@index([domainId])
}

model Setting {
  id        Int      @id @default(autoincrement())
  key       String   @unique
  value     String
  updatedAt DateTime @default(now()) @updatedAt
}

model ContactCheck {
  id         Int      @id @default(autoincrement())
  domainId   Int
  domain     Domain   @relation(fields: [domainId], references: [id], onDelete: Cascade)
  status     String // "found", "not_found", "error", "no_form"
  contactUrl String?
  message    String?
  checkedAt  DateTime @default(now())
}
